Package: uno
Type: Package
Title: Uno Card Game Engine with Simulation and Shiny Dashboard
Version: 0.1.0
Authors@R: c(
    person("Person", "A", role = c("aut", "cre"), email = "a@example.com"),
    person("Person", "B", role = "aut", email = "b@example.com"),
